# Copy to .env and fill in. NEVER commit .env.
# Paper keys: https://app.alpaca.markets (paper dashboard -> API keys)
ALPACA_PAPER_KEY_ID=your-paper-key-id
ALPACA_PAPER_SECRET_KEY=your-paper-secret

# Live keys — leave empty until the paper phase is done.
ALPACA_LIVE_KEY_ID=
ALPACA_LIVE_SECRET_KEY=

# FRED API key (https://fredaccount.stlouisfed.org/apikey) — reference data:
# macro release dates, risk-free rates, VIX.
FRED_API_KEY=your-fred-key

# paper | live
THETAD_MODE=paper
THETAD_PORT=7777
THETAD_DATA_DIR=./data
THETAD_STATE_FILE=./state/state.json
THETAD_JOURNAL_DIR=./journal
